# Valid client routes rewrite to the SPA shell with a 200 so deep links and
# refreshes resolve. Anything not listed here (and not a real static file such
# as /jobs.json, /robots.txt, /favicon.svg, /assets/*) falls through to
# Cloudflare's 404.html — a build-time copy of index.html — served with a real
# 404 status, so unknown URLs don't 200 with the app shell.
/jobs             /index.html   200
/studio           /index.html   200
/certifications   /index.html   200
/legal            /index.html   200
